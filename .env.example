# FocusLens - AI Study Intelligence System Configuration

# API Keys
# Get your Gemini API key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Get your Afferens Vision API key from: https://www.afferens.ai/
AFFERENS_API_KEY=your_afferens_api_key_here

# Database
DATABASE_PATH=focuslens.db

# Camera Settings
CAMERA_INDEX=0
FRAME_INTERVAL=5
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# Features
VOICE_ENABLED=true
VISION_API_ENABLED=true
ANALYTICS_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=focuslens.log

# Streamlit
STREAMLIT_THEME=dark

# Cooldown Periods (seconds)
VOICE_COOLDOWN=30
DISTRACTION_COOLDOWN=60

# Break Recommendations
BREAK_INTERVAL=40
BREAK_DURATION=5

# Focus Thresholds
FOCUS_SCORE_THRESHOLD=80

# Gemini Model Configuration
GEMINI_MODEL=gemini-2.5-flash
TEMPERATURE=0.7
MAX_TOKENS=500
